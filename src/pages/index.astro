---
import AboutExperience from "../components/about-experience.astro";
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import IconButton from "../components/icon-button.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
import experiences from "../collections/experiences.json";
---

<Layout title="Hi, I'm Elias!">
  <div
    class="relative z-20 w-full max-w-4xl mx-auto mt-16 px-7 md:mt-24 lg:mt-32 xl:px-0"
  >
    <div class="flex flex-col items-center md:flex-row">
      <div class="relative w-full md:w-1/2">
        <h1
          class="mb-5 text-4xl font-bold leading-tight md:text-4xl lg:text-6xl dark:text-white"
        >
          Hi, I'm Elias!
        </h1>
        <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
          I'm a front-end developer living in Brazil. <br
            class="hidden lg:block"
          />I focus on Web and Mobile development. <br
            class="hidden lg:block"
          />
        </p>
        <p class="mb-2 font-semibold text-neutral-800 dark:text-neutral-200">
          I can help you out with:
        </p>
        <ul
          class="py-2 space-y-[3px] text-sm list-disc list-inside text-neutral-500 dark:text-neutral-400"
        >
          <li>React.js Development</li>
          <li>Mobile Development</li>
          <li>Website Design</li>
          <li>and more...</li>
        </ul>
        <div class="flex items-center gap-1">
          <Button
            text="Download CV"
            link="/assets/cv/eliasacneto-cv.pdf"
            download="Elias A C Neto - CV"
          />
          <IconButton
            icon="fa-brands fa-linkedin-in fa-lg"
            link="https://linkedin.com/in/eliasacneto"
          />
          <IconButton
            icon="fa-brands fa-github fa-lg"
            link="https://github.com/eliasacneto"
          />
        </div>
      </div>
      <div
        class="relative justify-end hidden w-full mt-10 md:flex md:pl-10 md:w-1/2 md:mt-0 md:translate-y-4 xl:translate-y-0"
      >
        <div class="relative z-50 w-full">
          <div
            class="absolute bottom-0 z-40 w-16 h-16 -translate-x-6 -translate-y-1/2 lg:top-auto top-0 lg:-translate-y-[330px] rounded-full"
          >
            <span
              class="relative z-20 flex items-center justify-center w-full h-full text-2xl border-8 border-white rounded-full dark:border-neutral-950 bg-neutral-100 dark:bg-neutral-900"
            >
              <span
                class="flex items-center justify-center w-full h-full bg-white border border-dashed rounded-full dark:bg-neutral-950 border-neutral-300 dark:border-neutral-700"
                >👨🏻‍💻</span
              >
            </span>
          </div>
          <div class="relative z-30 px-1">
            <img
              src="/assets/images/2.png"
              loading="eager"
              decoding="auto"
              class="relative z-30 mb-1 w-full md:max-w-md mx-auto dark:-translate-y-0.5 rounded-lg"
            />
          </div>
          <div
            class="absolute bottom-0 right-0 z-20 w-full h-full lg:h-[420px] translate-x-0 -translate-y-px border border-dashed rounded-2xl bg-gradient-to-r dark:from-neutral-950 dark:via-black dark:to-neutral-950 from-white via-neutral-50 to-white border-neutral-300 dark:border-neutral-700"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
  <Separator text="A little bit about me" />
  <div class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="About Me"
      description="I hold a degree in Analysis and Systems Development, boasting solid experience in project management, user-friendly UI/UX interface development, website and web application creation, seamlessly integrating agile methodologies with programming best practices. I have a genuine passion for programming and I'm an advocate for usability and innovation-related themes!"
    />

    <div id="projects">
      <Separator text="Check out my projects" />
    </div>
    <Projects />

    <div id="experiences"></div>
    <Separator text="My work experiences" />

    <h2
      class="mt-1 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experiences
    </h2>
    <div class="px-5 py-10">
      {
        experiences.map((experience, loop) => {
          return (
            <>
              {loop == 0 || loop == 1 ? (
                <div class="pb-10 border-l border-gray-200 dark:border-neutral-700">
                  <AboutExperience
                    dates={experience.dates}
                    role={experience.role}
                    company={experience.company}
                    description={experience.description}
                    logo={experience.logo}
                  />
                </div>
              ) : (
                <AboutExperience
                  dates={experience.dates}
                  role={experience.role}
                  company={experience.company}
                  description={experience.description}
                  logo={experience.logo}
                />
              )}
            </>
          );
        })
      }
    </div>
  </div>
  <div id="contact"></div>

  <Separator text="Get in touch" />
  <div class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Let's Connect
    </h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      If you want to stay up to date with my work <a
        href="https://linkedin.com/in/eliasacneto"
        target="_blank"
        class="text-sky-600 underline">follow me on Linkedin</a
      >, or you can send me an <a
        href="mailto:netoeac.dev@gmail.com"
        class="text-sky-600 underline">email</a
      > and I'll be sure to get back to you.
    </p>
  </div>
  <div class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <a
      href="https://api.whatsapp.com/send?phone=5588997652020&text=Hi%20Elias,%20I%20saw%20your%20website%20and%20I'd%20like%20to%20talk%20to%20you%20about%20a%20project.%20%F0%9F%91%A8%F0%9F%8F%BB%E2%80%8D%F0%9F%92%BB"
      target="_blank"
      class="block w-full px-4 py-2 mt-5 text-[14px] font-semibold text-center duration-300 ease-out border rounded bg-neutral-900 dark:bg-neutral-100 dark:hover:border-neutral-300 dark:text-neutral-800 dark:hover:bg-neutral-950 dark:hover:text-neutral-100 text-neutral-100 border-neutral-900 hover:bg-white hover:text-neutral-900 font-bold"
    >
      <i class="fa-brands fa-whatsapp fa-lg"></i> Send me a message</a
    >
  </div>0
</Layout>
